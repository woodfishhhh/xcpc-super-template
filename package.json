    "idb": "^8.0.2",
    "jspdf": "^4.2.1",
    "monaco-editor": "^0.55.1",
    "pagedjs": "^0.4.3",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.22",
    "vue-draggable-plus": "^0.6.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^22.19.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.9.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
