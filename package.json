  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "validate:templates": "tsx scripts/validateTemplates.ts",
    "qa:pdf": "tsx scripts/renderPdfQaSamples.ts",
    "release:preflight": "tsx scripts/releasePreflight.ts",
    "release:preflight:final": "tsx scripts/releasePreflight.ts --final",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:all": "playwright test",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
