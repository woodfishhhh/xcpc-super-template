{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/woodfishhhh/xcpc-super-template/blob/main/板子/meta.schema.json",
  "title": "XCPC Super Template public template metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "category",
    "learningOrder",
    "tags",
    "timeComplexity",
    "spaceComplexity",
    "brief",
    "detail",
    "codeLanguage",
    "source",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "description": "Stable lowercase identifier, such as graph.shortest-path.dijkstra."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Must match the folder path below 板子/."
    },
    "learningOrder": {
      "type": "integer",
      "minimum": 0
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timeComplexity": {
      "type": "string",
      "minLength": 1
    },
    "spaceComplexity": {
      "type": "string",
      "minLength": 1
    },
    "brief": {
      "type": "string",
      "minLength": 1
    },
    "detail": {
      "type": "string",
      "minLength": 1
    },
    "codeLanguage": {
      "type": "string",
      "minLength": 1,
      "default": "cpp"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "license"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
